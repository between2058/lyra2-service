# =============================================================================
# Lyra-2 Service — machine-specific configuration
#
# Usage:
#   cp .env.example .env
#   vim .env
#   docker compose up -d
#
# .env is gitignored — never commit it.
# =============================================================================

# ── HuggingFace cache on host (shared by transformers/diffusers downloads) ───
# Default matches the standard phidias-model layout; change if your box differs.
HF_CACHE_HOST_PATH=/pegaai/model_team/huggingface_cache

# ── Lyra-2 explicit checkpoints (~50 GB) ─────────────────────────────────────
# The container's entrypoint.sh auto-downloads these on first startup if the
# directory is empty, so manual pre-download is no longer required. Just make
# sure the host directory is writable by docker.
#
# To pre-download manually (faster than waiting for first container start):
#   mkdir -p /pegaai/model_team/huggingface_cache/Lyra-2.0
#   cd /pegaai/model_team/huggingface_cache/Lyra-2.0
#   pip install huggingface_hub
#   huggingface-cli download nvidia/Lyra-2.0 --include "checkpoints/*" --local-dir .
LYRA2_CHECKPOINTS_PATH=/pegaai/model_team/huggingface_cache/Lyra-2.0/checkpoints

# ── HuggingFace token (REQUIRED for auto-download) ───────────────────────────
# nvidia/Lyra-2.0 is a gated repo. Steps:
#   1. Visit https://huggingface.co/nvidia/Lyra-2.0 and accept the license
#   2. Get a token at https://huggingface.co/settings/tokens (read access)
#   3. Paste it here
# Not needed if you pre-downloaded the checkpoints manually (above).
HF_TOKEN=

# ── Build settings ───────────────────────────────────────────────────────────
# 12.0 = RTX Pro 6000 Blackwell only (faster build).
# Multi-GPU compatibility: TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0;10.0;12.0
TORCH_CUDA_ARCH_LIST=12.0

# Parallel compile jobs (raise on multi-core build machines)
MAX_JOBS=4

# Optional corporate proxy (leave empty otherwise)
HTTP_PROXY=
HTTPS_PROXY=

# ── Runtime ──────────────────────────────────────────────────────────────────

# GPU index (run `nvidia-smi` to list)
LYRA2_GPU_ID=0

# Public port (nginx listens here)
LYRA2_PORT=52075

# Inference queue depth — each job runs minutes
LYRA2_QUEUE_MAX_SIZE=3

# Torch VRAM ceiling for leak detection (GB) — Lyra-2 ~70 GB peak
LYRA2_TORCH_VRAM_LEAK_LIMIT_GB=80.0
